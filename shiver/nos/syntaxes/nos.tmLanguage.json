{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "NOS",
	"patterns": [
    	{ "include": "#comments" },
    	{ "include": "#labels" },
    	{ "include": "#block" },
		{ "include": "#operations" },
    	{ "include": "#commands" }
	],
	"repository": {
    	"comments": {
    		"name": "comment.line.number-sign.nos",
    		"match": "#.*$"
    	},
		"labels": {
    		"name": "support.function",
    	  	"begin": "@",
    	  	"end": "(?= |$)",
			"patterns": [
				{"include": "#commands"}
			]
    	},
    	"block": {
    	  "patterns": [
    	    {
    	      "name": "punctuation.section.block.begin.nos",
    	      "match": "\\{"
    	    },
    	    {
    	      "name": "punctuation.section.block.end.nos",
    	      "match": "\\}"
    	    }
    	  ]
    	},
		"operations": {
			"patterns": [
				{
    	    	  "begin": "^(\\s*)(?=(forEach|run|runInLine|loadScript|getLoadingScriptsAmount|cancelScript|message|setGlobal)\\b)",
    	    	  "end": "(?=\\n|$)",
    	    	  "beginCaptures": {
    	    	    "2": { "name": "keyword.control.command.nos" }
    	    	  },
    	    	  "patterns": [
    	    	    {"include": "#string"},
  					{"include": "#block"}
    	    	  ]
    	    	}
			]
		},
    	"commands": {
    	  "patterns": [
    	    	{
    	    	  "begin": "^(\\s*)(?=(print|jump|set|wait|if|signal|actionbar|pass|list|dict|cancelScript|numList|parallel)\\b)",
    	    	  "end": "(?=\\n|$)",
    	    	  "beginCaptures": {
    	    	    "2": { "name": "keyword.control.command.nos" }
    	    	  },
    	    	  "patterns": [
    	    	    {
    	    	      "include": "#arguments"
    	    	    }
    	    	  ]
    	    	},
				{
    	    	  "begin": "^(\\s*)(Sentry\\.[^\\s]+)",
    	    	  "end": "(?=\\n|$)",
    	    	  "beginCaptures": {
    	    	    "2": { "name": "support.type" }
    	    	  },
    	    	  "patterns": [
    	    	    {
    	    	      "include": "#arguments"
    	    	    }
    	    	  ]
    	    	},
				{
    	    	  "begin": "^(\\s*)(Immunator\\.[^\\s]+)",
    	    	  "end": "(?=\\n|$)",
    	    	  "beginCaptures": {
    	    	    "2": { "name": "support.type" }
    	    	  },
    	    	  "patterns": [
    	    	    {
    	    	      "include": "#arguments"
    	    	    }
    	    	  ]
    	    	},
				{
    	    	  "begin": "^(\\s*)(C4\\.[^\\s]+)",
    	    	  "end": "(?=\\n|$)",
    	    	  "beginCaptures": {
    	    	    "2": { "name": "support.type" }
    	    	  },
    	    	  "patterns": [
    	    	    {
    	    	      "include": "#arguments"
    	    	    }
    	    	  ]
    	    	},
				{
    	    	  "begin": "^(\\s*)(Radar\\.[^\\s]+)",
    	    	  "end": "(?=\\n|$)",
    	    	  "beginCaptures": {
    	    	    "2": { "name": "support.type" }
    	    	  },
    	    	  "patterns": [
    	    	    {
    	    	      "include": "#arguments"
    	    	    }
    	    	  ]
    	    	},
				{
    	    	  "begin": "^(\\s*)(World\\.[^\\s]+)",
    	    	  "end": "(?=\\n|$)",
    	    	  "beginCaptures": {
    	    	    "2": { "name": "support.type" }
    	    	  },
    	    	  "patterns": [
    	    	    {
    	    	      "include": "#arguments"
    	    	    }
    	    	  ]
    	    	},
				{
    	    	  "begin": "^(\\s*)(Shiver\\.[^\\s]+)",
    	    	  "end": "(?=\\n|$)",
    	    	  "beginCaptures": {
    	    	    "2": { "name": "support.type" }
    	    	  },
    	    	  "patterns": [
    	    	    {
    	    	      "include": "#arguments"
    	    	    }
    	    	  ]
    	    	},
				{
    	    	  "begin": "^(\\s*)(Entity\\.[^\\s]+)",
    	    	  "end": "(?=\\n|$)",
    	    	  "beginCaptures": {
    	    	    "2": { "name": "support.type" }
    	    	  },
    	    	  "patterns": [
    	    	    {
    	    	      "include": "#arguments"
    	    	    }
    	    	  ]
    	    	},
				{
    	    	  "begin": "^(\\s*)(Player\\.[^\\s]+)",
    	    	  "end": "(?=\\n|$)",
    	    	  "beginCaptures": {
    	    	    "2": { "name": "support.type" }
    	    	  },
    	    	  "patterns": [
    	    	    {
    	    	      "include": "#arguments"
    	    	    }
    	    	  ]
    	    	},
				{
    	    	  "begin": "^(\\s*)(list\\.[^\\s]+)",
    	    	  "end": "(?=\\n|$)",
    	    	  "beginCaptures": {
    	    	    "2": { "name": "support.type" }
    	    	  },
    	    	  "patterns": [
    	    	    {
    	    	      "include": "#arguments"
    	    	    }
    	    	  ]
    	    	},
				{
    	    	  "begin": "^(\\s*)(dict\\.[^\\s]+)",
    	    	  "end": "(?=\\n|$)",
    	    	  "beginCaptures": {
    	    	    "2": { "name": "support.type" }
    	    	  },
    	    	  "patterns": [
    	    	    {
    	    	      "include": "#arguments"
    	    	    }
    	    	  ]
    	    	}
    		]
    	},
    	"arguments": {
    	  "patterns": [
    	    {
    	      "include": "#string"
    	    },
    	    {
    	      "include": "#variable"
    	    },
    	    {
    	      "include": "#global"
    	    },
			{
    	      "include": "#number"
    	    },
    	    {
    	      "name": "text.argument.nos",
    	      "match": "[^\\s]+"
    	    }
    	  ]
    	},
    	"string": {
    	  "name": "string",
    	  "begin": "'",
    	  "end": "'"
    	},
		"variable": {
    	  "name": "variable.other.nos",
		  "begin": "var\\(",
		  "end": "\\)"
    	},
    	"number": {
    	  "name": "constant.numeric.nos",
    	  "match": "-?\\d+(\\.\\d+)?"
    	},
    	"global": {
    	  "name": "variable.other.global",
    	  "match": "global\\([^)]*\\)"
    	}
	},
	"scopeName": "source.nos"
}