# Shiver map script | REPIS
# Player join in game event
# Variables:
# - player - Player
# - reason - Player join reason (1 - by User, 2 - by Script, 3 - antidot)

if var(reason) < 3 {
    Player.sendBedAnimation 'var(player)'
    Entity.tp 'var(player)' 218; 42; -73; 0; 0;
    Shiver.giveKitStart 'var(player)'
}
if var(reason) == 3 {
    
}
