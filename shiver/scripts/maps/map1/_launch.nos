# Shiver map script | REPIS

# Scripts load
loadScript 'maps/common/launch'
loadScript 'maps/common/prepare'
loadScript 'maps/common/wave_tick'
loadScript 'maps/common/globals'
loadScript 'maps/map1/waves'
loadScript 'maps/map1/_join'
loadScript 'maps/map1/_lose'

## Loading wait
@scriptsLoading
getLoadingScriptsAmount 'inLoading'
if var(inLoading) > 0 {
    wait 3
    jump 'scriptsLoading'
}

# Default Prepare
Shiver.music 'shiver:music.theme3'
setGlobal 'MAP_TITLE' '<white>🌊 Маяк'
setGlobal 'PREPARE_TIME' 1800
setGlobal 'LOOT_CHANCE' 0.7

run 'maps/common/globals' '*'
run 'maps/map1/waves' '*'
runInLine 'maps/common/launch'

# Preparing
World.time 13100
Shiver.addZombieSpawn 'default' 218.5; 42; 18.5; 180; 0

# Cutscenes
parallel '*' {
    World.setBlocks 0; 'light' 218; 46; -75; 218; 46; -75;
    Shiver.getProp 'tonel.light' 'lamp'
    set 'off' 'e2NvbXBvbmVudHM6eyJtaW5lY3JhZnQ6Y3VzdG9tX21vZGVsX2RhdGEiOntmbG9hdHM6WzEwMTQ2LjBmXX19LGNvdW50OjEsaWQ6Im1pbmVjcmFmdDpsZWF0aGVyX2hvcnNlX2FybW9yIn0='
    set 'on' 'e2NvbXBvbmVudHM6eyJtaW5lY3JhZnQ6Y3VzdG9tX21vZGVsX2RhdGEiOntmbG9hdHM6WzEwMTQ3LjBmXX19LGNvdW50OjEsaWQ6Im1pbmVjcmFmdDpsZWF0aGVyX2hvcnNlX2FybW9yIn0='
    Shiver.getCameraDuration 'map1.camera1' 'w'
    wait var(w)
    World.weather 'thunder'
    Shiver.getCameraDuration 'map1.camera2' 'w'
    dict 'tasks'
    Shiver.spawnClones 218.5; 42; -72.5; 'tasks' 4
    Shiver.getClones 'clones'
    dict.values 'clones' 'clones_ents'
    forEach '*' 'ent' 'clones_ents' {
        Entity.effect 'var(ent)' 'slowness' -1; 127; 0; 0; 1;
    }
    wait var(w)
    Entity.lightingbolt 290; 43; -38;
    wait 40
    World.setBlocks 0; 'air' 218; 46; -75; 218; 46; -75;
    Entity.itemDisplaySetItem 'var(lamp)' 'var(off)'
    wait 10
    World.setBlocks 0; 'light' 218; 46; -75; 218; 46; -75;
    Entity.itemDisplaySetItem 'var(lamp)' 'var(on)'
    wait 5
    World.setBlocks 0; 'air' 218; 46; -75; 218; 46; -75;
    Entity.itemDisplaySetItem 'var(lamp)' 'var(off)'

}
parallel '*' {
    World.sound 'shiver:ambience.map1heli' 16; 1.1; 242.59; 53.11; -51.84;
    Entity.spawnItemDsiplay 'helicopter' 145.9; 52.4; -8.8; 180; -5; 'global(EMPTY_ITEMSTACK)'
    Entity.displaySetScale 'var(helicopter)' 8; 8; 8;
    Entity.displayRotations 'var(helicopter)' 90; 0; 0; 'set'
    Entity.displaySetOffset 'var(helicopter)' -120; 40; -150;
    Entity.displayInterpolation 'var(helicopter)' 10; 100;
    wait 1
    Entity.itemDisplaySetItem 'var(helicopter)' 'e2NvbXBvbmVudHM6eyJtaW5lY3JhZnQ6Y3VzdG9tX21vZGVsX2RhdGEiOntmbG9hdHM6WzEwMDcxLjBmXX19LGNvdW50OjEsaWQ6Im1pbmVjcmFmdDpsZWF0aGVyX2hvcnNlX2FybW9yIn0='
    wait 5
    Entity.displaySetOffset 'var(helicopter)' -120.0; 30.0; 150.0;
    Entity.displayRotations 'var(helicopter)' 90; 25; 0; 'set'
    wait 8 * 20
    Entity.remove 'var(helicopter)'
}
list 'cameras'
list.add 'cameras' 'map1.camera1'
list.add 'cameras' 'map1.camera2'
list.add 'cameras' 'map1.camera4'
forEach '*' 'camera' 'cameras' {
    Shiver.spawnCamera 'var(camera)'
}
wait 2
forEach '*' 'camera' 'cameras' {
    Shiver.getCameraDuration 'var(camera)' 'duration'
    numList 'frames' 0; var(duration) - 1; 1;
    forEach '*' 'frame' 'frames' {
        Shiver.cameraFrame 'var(camera)' var(frame)
        wait 1
    }
}
World.sound 'shiver:ambience.memory' 1; 1; 203.5; 44.5; -59.5;

### Spawn
Shiver.removeClones
Shiver.getPlayers 'players'
forEach '*' 'ply' 'players' {
    Shiver.callJoin 'var(ply)'
}
Shiver.makeLeader

setGlobal 'PREPARE_TIME' 90
setGlobal 'TICK_HANDLER' 'maps/common/wave_tick'
run 'maps/common/prepare' '*'
###

wait 20
Shiver.showActionbar 'wait' global(LORE_SPEED); 'global(LORE_PREFIX)' 'Вертолёт пролетел в сторонну запечатанного тонеля...'
wait var(wait) + 40
Shiver.showActionbar 'wait' global(LORE_SPEED); 'global(LORE_PREFIX)' 'Значит это правда, город выживших существует...'
wait var(wait) + 40
Shiver.showActionbar 'wait' global(LORE_SPEED); 'global(LORE_PREFIX)' 'Но похоже, нам не открыть эти железные двери.'
wait var(wait) + 30
Entity.lightingbolt 236.83; 57.0; -2.69;
World.stopSound 'shiver:ambience.memory'
Shiver.getProp 'big_house.tv' 'tv'
Entity.itemDisplaySetItem 'var(tv)' ''